# Example environment file for `docker run --env-file docker-run.env`.
#
# Usage:
#   docker run --rm -p 9001:9001 \
#     --env-file examples/docker-run.env \
#     -v $(pwd)/examples/rules.policy:/etc/guardrails/rules.policy:ro \
#     ghcr.io/soulwhisper/extmcp-guardrail:0.1.0
#
# Every variable here mirrors guardrails/config.py defaults. Uncomment and
# edit the lines you want to override.

# ----- Policy ----------------------------------------------------------------
# failClosed: deny on scanner failure / timeout (recommended for write-capable
# agents). failOpen: allow with a review flag (only when guardrail outage is
# judged less harmful than blocking the agent).
FAILURE_MODE=failClosed

# How HUMAN_REVIEW outcomes are resolved by the aggregator.
#   pass — forward the exchange and emit an audit warning (homelab default).
#   deny — escalate every HUMAN_REVIEW to a hard deny (stricter).
HUMAN_REVIEW_MODE=pass

# ----- Scanners --------------------------------------------------------------
# Max bytes of text fed to any scanner. Tool output beyond this is truncated
# (UTF-8-safe on a character boundary) and the decision is flagged
# `truncated=true` in the audit log. 32KiB covers the attacker-relevant head
# of any payload while keeping P95 latency bounded.
MAX_CONTENT_BYTES=32768

# Deterministic pattern scanner (hidden ASCII / PII / secrets). Zero ML deps.
ENABLE_REGEX_SCANNER=1

# LlamaFirewall semantic scanners (PromptGuard-2 + CodeShield). When the
# llamafirewall package is absent the engine falls back to regex-only and
# logs a warning.
ENABLE_LLAMAFIREWALL=1

# AgentAlignment is LLM-based (~300-800ms). Default off for homelab; only
# triggered as a second stage when PromptGuard flags HUMAN_REVIEW on the
# response side. Set to 1 to enable the cost-bounded deep-inspection path.
ENABLE_AGENT_ALIGNMENT=0

# ----- Invariant -------------------------------------------------------------
# Sliding-window size for the cross-call toxic-flow trace. 64 covers a typical
# homelab agent tool-use chain; bump for long multi-step plans.
INVARIANT_WINDOW=64

# Rule pack source. Point at a file path for hot-reloadable rule packs
# (SIGHUP the server process to reload without dropping connections):
#   kill -HUP 1
INVARIANT_RULES_PATH=/etc/guardrails/rules.policy

# Alternatively, a dotted Python module path (useful for tests / bundled
# packs). Leave commented to use INVARIANT_RULES_PATH above.
# INVARIANT_RULES_MODULE=guardrails.rules.default

# ----- Timing ----------------------------------------------------------------
# Per-scanner deadline in milliseconds. Exceeded -> treated per FAILURE_MODE.
# Keep sidecar < gateway so the sidecar decides first.
SCANNER_TIMEOUT_MS=500

# ----- Networking ------------------------------------------------------------
# Bind address. [::]:9001 listens on all interfaces, IPv4 and IPv6.
# Use 127.0.0.1:9001 to bind loopback only (e.g. for sidecar-on-localhost).
LISTEN_ADDR=[::]:9001

# grpc.aio ThreadPoolExecutor size. Each in-flight RPC occupies one worker;
# raise for high-concurrency deployments.
SERVER_MAX_WORKERS=8

# ----- Observability ---------------------------------------------------------
# OTLP/gRPC endpoint (e.g. http://otel-collector.observability.svc:4317).
# When unset or when the OTel SDK is absent, the sidecar degrades to
# audit-log-only operation.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc:4317

# Service name reported on OTel spans/metrics.
OTEL_SERVICE_NAME=extmcp-guardrail

# Append-only JSONL audit log. "-" or unset -> stdout. Set to a path for a
# durable, GitOps-friendly audit trail that survives OTel outages.
# AUDIT_LOG_PATH=/var/log/guardrail/audit.jsonl
AUDIT_LOG_PATH=-

# ----- Misc ------------------------------------------------------------------
# Dry-run mode: replace all real scanners with allow-stubs. Use to validate
# wiring without loading ML models.
# GUARDRAIL_DRY_RUN=1
GUARDRAIL_DRY_RUN=0

# Python logging level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
